{
  "manifest_version": 3,
  "name": "Survey Auto-Filler",
  "version": "1.0",
  "description": "Automatically fills surveys on Menofia Education Portal.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://stdch.menofia.education/*",
        "*://*.menofia.education/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
